import { BrowserRouter, Routes, Route } from 'react-router-dom';
import { Layout } from './components/Layout';
import { RoomPage } from './pages/RoomPage';

const Dashboard = () => (
  <div className="p-8">
    <div className="max-w-4xl">
      <h1 className="text-4xl font-bold mb-4 tracking-tight">Infrastructure Dashboard</h1>
      <p className="text-gray-400 text-lg mb-8">
        Welcome to the physical monitoring view. Use the sidebar to navigate through your sites and rooms.
      </p>
      
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { label: 'Global Status', value: 'Healthy', color: 'text-status-ok' },
          { label: 'Active Alerts', value: '0', color: 'text-gray-500' },
          { label: 'System Load', value: 'Normal', color: 'text-blue-400' },
        ].map((stat, i) => (
          <div key={i} className="bg-rack-panel border border-rack-border p-6 rounded-lg">
            <p className="text-[10px] uppercase font-bold text-gray-500 tracking-widest mb-2">{stat.label}</p>
            <p className={`text-2xl font-mono ${stat.color}`}>{stat.value}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
);

function App() {
  return (
    <BrowserRouter>
      <Layout>
        <Routes>
          <Route path="/" element={<Dashboard />} />
          <Route path="/room/:roomId" element={<RoomPage />} />
        </Routes>
      </Layout>
    </BrowserRouter>
  );
}

export default App;